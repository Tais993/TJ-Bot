# Normalize to LF in the index AND in the working tree on all platforms.
# Spotless enforces LF, so without eol=lf, Windows/WSL checkouts get CRLF and
# every spotlessApply rewrites every file.
* text=auto eol=lf

# Explicit for linux files
*.sh     text eol=lf

# Explicit stuff for win files
*.bat    text eol=crlf

# Just to make sure git doesn't corrupt our binaries accidentally, it's a good practice.
*.gif  binary
*.jpg  binary
*.jpeg binary
*.png  binary

# No extensions, so we set them manually
/gradlew           text eol=lf
